{
  "name": "screenshot",
  "module": "src/server.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run css:watch\" \"bun --smol --hot src/server.tsx\"",
    "start": "bun run css:build && bun --smol src/server.tsx",
    "css:build": "tailwindcss -i ./src/index.css -o ./public/index.css --minify",
    "css:watch": "tailwindcss -i ./src/index.css -o ./public/index.css --watch",
    "lint": "biome check --write",
    "test": "bun test",
    "cleanup": "bun --smol src/db/cleanup.ts",
    "purge": "bun --smol src/db/purge.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@tailwindcss/cli": "^4.1.14",
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@duckduckgo/autoconsent": "^14.71.0",
    "@hatchet-dev/typescript-sdk": "^1.19.1",
    "@hono/react-renderer": "^1.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "hono": "^4.12.11",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14"
  }
}
